{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "allowJs": false,
    "noEmit": false,
    "outDir": "source/class",
    "rootDir": "source/class",
    "strict": false,
    "skipLibCheck": true,
    "baseUrl": ".",
    "declaration": false
  },
  "include": [
    "source/class/**/*.ts",
    "source/class/**/*.d.ts"
  ],
  "exclude": ["node_modules", "compiled"]
}
